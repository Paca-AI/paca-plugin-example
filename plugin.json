{
  "id": "com.paca.example",
  "displayName": "Plugin SDK Hello World",
  "description": "Hello world examples for every Paca plugin SDK feature.",
  "version": "0.1.0",
  "permissions": ["db.read", "db.write", "events.subscribe", "events.emit"],
  "backend": {
    "eventSubscriptions": ["task.deleted"],
    "routes": [
      {
        "method": "GET",
        "path": "/projects/:projectId/hello",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.read"]
          }
        ]
      },
      {
        "method": "POST",
        "path": "/projects/:projectId/hello",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.write"]
          }
        ]
      },
      {
        "method": "PATCH",
        "path": "/projects/:projectId/hello/:id",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.write"]
          }
        ]
      },
      {
        "method": "DELETE",
        "path": "/projects/:projectId/hello/:id",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.write"]
          }
        ]
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/hello/plain",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.read"]
          }
        ]
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/hello/stats",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.read"]
          }
        ]
      },
      {
        "method": "DELETE",
        "path": "/projects/:projectId/hello/stats/cache",
        "middlewares": [
          { "name": "optionalAuthn" },
          { "name": "requireFreshPassword" },
          {
            "name": "requirePermissions",
            "scope": "project",
            "permissions": ["projects.write"]
          }
        ]
      }
    ]
  },
  "frontend": {
    "remoteEntryUrl": "/plugins/com.paca.example/assets/remoteEntry.js",
    "extensionPoints": [
      {
        "point": "sidebar.general.section",
        "component": "HelloGeneralSection",
        "order": 10
      },
      {
        "point": "sidebar.project.section",
        "component": "HelloProjectSection",
        "order": 10
      },
      {
        "point": "task.detail.section",
        "component": "HelloTaskSection",
        "order": 10
      },
      {
        "point": "project.settings.tab",
        "component": "HelloProjectSettingsTab",
        "order": 10
      },
      {
        "point": "view",
        "component": "HelloView",
        "order": 10
      }
    ]
  },
  "mcp": {
    "remoteEntryUrl": "/plugins-mcp/com.paca.example/mcp.js"
  }
}
